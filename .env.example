# ---- Boutique : réception des commandes ----
# URL de l'application web Google Apps Script (finit par /exec, voir docs/BOUTIQUE.md).
ORDER_WEBHOOK_URL=

# Secret partagé entre le site et l'Apps Script (doit être IDENTIQUE à la
# constante TOKEN du script). Protège l'écriture des commandes et la lecture
# des données côté admin. Mets une chaîne aléatoire longue.
ORDER_WEBHOOK_TOKEN=

# ---- Espace admin (/admin) ----
# Mot de passe unique d'accès à la page d'administration des commandes.
ADMIN_PASSWORD=
